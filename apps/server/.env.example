# ─── ParentingMyKid Server — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it contains secrets.

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# ─── Database (Neon.tech — Free PostgreSQL) ───────────────────────────────────
# Sign up at: https://neon.tech — no credit card required
# Format: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/parentingmykid
DATABASE_URL=postgresql://USER:PASSWORD@HOST/parentingmykid?sslmode=require

# ─── Redis (Upstash — Free Redis) ─────────────────────────────────────────────
# Sign up at: https://upstash.com — no credit card required
# Get both values from your Upstash dashboard after creating a database
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS_ID.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-different-from-above
JWT_REFRESH_EXPIRES_IN=7d

# ─── Child PIN (parent can see digits after reinstall) ─────────────────────────
# AES-GCM key for `ChildProfile.pinEnc`. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep stable in production — changing it invalidates existing `pinEnc` values.
CHILD_PIN_ENCRYPTION_KEY=your-64-char-hex-or-long-random-string-at-least-16-chars

# ─── Cloudinary (Free Media Storage) ──────────────────────────────────────────
# Sign up at: https://cloudinary.com — no credit card required
# Find all 3 values in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── OpenAI (AI Features) ─────────────────────────────────────────────────────
# Sign up at: https://platform.openai.com — pay-as-you-go, cheap to start
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Resend (Email Service — Free 3,000 emails/month) ─────────────────────────
# Sign up at: https://resend.com — free tier, no credit card for basic use
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@parentingmykid.com
# Public marketing site (https://…) — used in emails for links and the /logo.png image. Defaults to production if unset.
PUBLIC_WEB_URL=https://www.parentingmykid.com

# ─── RevenueCat (In-App Purchases) ────────────────────────────────────────────
# Sign up at: https://app.revenuecat.com — free up to $2,500/month revenue
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# ─── Expo Push Notifications ─────────────────────────────────────────────────
# No API key needed — Expo's push service is free and handles FCM + APNs
# Just use expo-server-sdk in the notifications module

# ─── Prayer Times API ─────────────────────────────────────────────────────────
# Free API from aladhan.com — no key required for basic use
PRAYER_TIMES_API_URL=https://api.aladhan.com/v1

# ─── Frontend URLs (CORS) ─────────────────────────────────────────────────────
# Include the marketing Next.js dev server (see apps/web) and production site origin.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:4001,exp://192.168.1.x:8081

# ─── Marketing leads (Prisma) ─────────────────────────────────────────────────
# After schema changes that add `Lead` / `SiteFeedback`, sync the database:
#   npm run db:push -w @parentingmykid/server
