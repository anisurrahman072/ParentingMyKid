# ─── ParentingMyKid Server — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it contains secrets.

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# ─── Database (MongoDB Atlas — Free M0 Tier) ──────────────────────────────────
# Sign up at: https://www.mongodb.com/atlas — free M0 cluster, no credit card required
# Format: mongodb+srv://user:password@cluster.mongodb.net/parentingmykid?retryWrites=true&w=majority
# Where to add this: Render dashboard → your API service → Environment → Add MONGODB_URI
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/parentingmykid?retryWrites=true&w=majority

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long
# Long-lived mobile sessions (shorter values = more refresh traffic and harsher offline behavior)
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-different-from-above
JWT_REFRESH_EXPIRES_IN=365d

# ─── PIN recovery encryption (child + parental "My PIN" on reinstall) ──────────
# AES-GCM key for `ChildProfile.pinEnc` and `User.parentalPinEnc`. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep stable in production — changing it invalidates existing encrypted PIN fields.
CHILD_PIN_ENCRYPTION_KEY=your-64-char-hex-or-long-random-string-at-least-16-chars

# ─── Cloudinary (Free Media Storage) ──────────────────────────────────────────
# Sign up at: https://cloudinary.com — no credit card required
# Find all 3 values in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── OpenAI (AI Features) ─────────────────────────────────────────────────────
# Sign up at: https://platform.openai.com — pay-as-you-go, cheap to start
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Resend (Email Service — Free 3,000 emails/month) ─────────────────────────
# Sign up at: https://resend.com — free tier, no credit card for basic use
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@parentingmykid.com
# Public marketing site (https://…) — used in emails for links and the /logo.png image.
PUBLIC_WEB_URL=https://www.parentingmykid.com

# ─── RevenueCat (In-App Purchases) ────────────────────────────────────────────
# Sign up at: https://app.revenuecat.com — free up to $2,500/month revenue
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# ─── Expo Push Notifications ─────────────────────────────────────────────────
# No API key needed — Expo's push service is free and handles FCM + APNs
# Just use expo-server-sdk in the notifications module

# ─── Prayer Times API ─────────────────────────────────────────────────────────
# Free API from aladhan.com — no key required for basic use
PRAYER_TIMES_API_URL=https://api.aladhan.com/v1

# ─── Frontend URLs (CORS) ─────────────────────────────────────────────────────
# Include the marketing Next.js dev server (see apps/web) and production site origin.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:4001,exp://192.168.1.x:8081

# ─── Socket.IO Real-Time Server ───────────────────────────────────────────────
# URL of the dedicated Socket.IO server (apps/socket-server) deployed to Render.
# Used by mobile app to connect to live parent-kid monitoring.
# Where to add this: also set EXPO_PUBLIC_SOCKET_URL in apps/mobile/.env
SOCKET_SERVER_URL=https://pmk-socket.onrender.com

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
