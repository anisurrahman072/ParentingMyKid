# Local dev only: Vercel does not send x-vercel-ip-country on localhost.
# Set this to BD to simulate Bangladesh ("/" → /bn). Omit or use any non-BD code for "/" → /en.
# GEO_SIMULATE_COUNTRY=BD

# Facebook Graph API — landing page “latest posts” feed (server-only; never NEXT_PUBLIC_*).
# Use a Page access token with pages_read_engagement. Optional read_insights for post “views”
# (impressions) in the UI. See: https://developers.facebook.com/docs/graph-api/reference/page/feed
# FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional numeric or string page id (defaults to the page username ParentingMyKid.page).
# FACEBOOK_PAGE_ID=ParentingMyKid.page

# Google Search Console — HTML tag verification (optional; server-only, never NEXT_PUBLIC_*)
# GOOGLE_SITE_VERIFICATION=your_verification_string

# Marketing site — public (embedded in browser bundle)
# Google Analytics 4 Measurement ID (analytics.google.com)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Meta Pixel ID (business.facebook.com → Events Manager)
# NEXT_PUBLIC_FB_PIXEL_ID=123456789012345
# NestJS API base URL for lead capture (no trailing slash), e.g. http://localhost:3001
# NEXT_PUBLIC_SERVER_URL=http://localhost:3001
