# ─── PMK Socket.IO Server — Environment Variables ────────────────────────────
# Copy to .env and fill in your values.
# Deploy this service separately to Render → Web Service.

# Port (Render sets this automatically; leave as default for local dev)
PORT=3002

# Must match the JWT_SECRET in apps/server/.env exactly.
# Both services share the same secret so JWT tokens issued by the NestJS API
# can be verified here without any extra round-trip.
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long

# Comma-separated list of allowed CORS origins.
# Include your Expo dev URL, production domain, and the NestJS API URL.
ALLOWED_ORIGINS=http://localhost:8081,exp://192.168.1.x:8081,https://parentingmykid.com
