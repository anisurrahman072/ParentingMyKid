# Optional: Google Sign-In — Web OAuth client id (see apps/mobile/docs/GOOGLE_SIGN_IN_ANDROID.md)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com

# Optional: override API base (include /api/v1). Use when Expo cannot infer your PC IP
# (e.g. tunnel mode) or the backend runs on another host.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.50:3001/api/v1
